{
  "family": "marketplace-prod",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "executionRoleArn": "arn:aws:iam::<aws-account-id>:role/marketplace-prod-ecs-execution-role",
  "taskRoleArn": "arn:aws:iam::<aws-account-id>:role/marketplace-prod-ecs-task-role",
  "containerDefinitions": [
    {
      "name": "marketplace",
      "image": "<aws-account-id>.dkr.ecr.<aws-region>.amazonaws.com/marketplace:latest",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 3000,
          "hostPort": 3000,
          "protocol": "tcp",
          "appProtocol": "http"
        }
      ],
      "environment": [
        {
          "name": "NODE_ENV",
          "value": "production"
        },
        {
          "name": "PORT",
          "value": "3000"
        },
        {
          "name": "HOSTNAME",
          "value": "0.0.0.0"
        },
        {
          "name": "NEXT_PUBLIC_APP_URL",
          "value": "https://your-domain.example.com"
        },
        {
          "name": "NEXT_PUBLIC_SUPABASE_URL",
          "value": "https://your-project-ref.supabase.co"
        },
        {
          "name": "NEXT_PUBLIC_SUPABASE_ANON_KEY",
          "value": "replace-with-public-anon-key-or-use-ssm"
        }
      ],
      "secrets": [
        {
          "name": "SUPABASE_SERVICE_ROLE_KEY",
          "valueFrom": "arn:aws:ssm:<aws-region>:<aws-account-id>:parameter/marketplace/prod/supabase-service-role-key"
        },
        {
          "name": "STRIPE_SECRET_KEY",
          "valueFrom": "arn:aws:ssm:<aws-region>:<aws-account-id>:parameter/marketplace/prod/stripe-secret-key"
        },
        {
          "name": "STRIPE_WEBHOOK_SECRET",
          "valueFrom": "arn:aws:ssm:<aws-region>:<aws-account-id>:parameter/marketplace/prod/stripe-webhook-secret"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/marketplace-prod",
          "awslogs-region": "<aws-region>",
          "awslogs-stream-prefix": "ecs"
        }
      },
      "healthCheck": {
        "command": [
          "CMD-SHELL",
          "wget --no-verbose --tries=1 --spider http://127.0.0.1:3000/api/health || exit 1"
        ],
        "interval": 30,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 60
      }
    }
  ],
  "runtimePlatform": {
    "cpuArchitecture": "X86_64",
    "operatingSystemFamily": "LINUX"
  }
}
