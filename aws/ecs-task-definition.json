{
  "family": "multi-vendor-marketplace-task",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "1024",
  "memory": "2048",
  "executionRoleArn": "arn:aws:iam::681432799427:role/ecsTaskExecutionRole-marketplace",
  "containerDefinitions": [
    {
      "name": "marketplace",
      "image": "681432799427.dkr.ecr.eu-central-1.amazonaws.com/multi-vendor-marketplace:latest",
      "essential": true,
      "portMappings": [
        {
          "name": "marketplace-3000",
          "containerPort": 3000,
          "hostPort": 3000,
          "protocol": "tcp",
          "appProtocol": "http"
        }
      ],
      "environment": [
        {
          "name": "NODE_ENV",
          "value": "production"
        },
        {
          "name": "NEXT_TELEMETRY_DISABLED",
          "value": "1"
        },
        {
          "name": "NEXT_PUBLIC_APP_URL",
          "value": "http://marketplace-alb-1795663621.eu-central-1.elb.amazonaws.com"
        },
        {
          "name": "PORT",
          "value": "3000"
        },
        {
          "name": "HOSTNAME",
          "value": "0.0.0.0"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/multi-vendor-marketplace",
          "awslogs-region": "eu-central-1",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ],
  "runtimePlatform": {
    "cpuArchitecture": "X86_64",
    "operatingSystemFamily": "LINUX"
  }
}